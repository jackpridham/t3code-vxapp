{
  "name": "@t3tools/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "4.0.0-beta.43",
      "@effect/openapi-generator": "4.0.0-beta.43",
      "@effect/platform-node": "4.0.0-beta.43",
      "@effect/sql-sqlite-bun": "4.0.0-beta.43",
      "@effect/vitest": "4.0.0-beta.43",
      "@effect/language-service": "0.84.2",
      "@types/bun": "^1.3.9",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.ts dev",
    "dev:server": "node scripts/dev-runner.ts dev:server",
    "dev:web": "node scripts/dev-runner.ts dev:web",
    "start": "turbo run start --filter=t3",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck --only --filter=t3 --filter=@t3tools/web --filter=@t3tools/shared --filter=@t3tools/contracts --filter=@t3tools/orchestration-core --filter=@t3tools/scripts",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build:contracts": "turbo run build --filter=@t3tools/contracts",
    "release:smoke": "node scripts/release-smoke.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo",
    "sync:vscode-icons": "node scripts/sync-vscode-icons.mjs"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "vitest": "catalog:"
  },
  "overrides": {
    "vite": "^8.0.0"
  },
  "engines": {
    "bun": "^1.3.9",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.9",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  },
  "trustedDependencies": [
    "node-pty"
  ]
}
